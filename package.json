{
  "name": "scriptflow",
  "version": "1.0.0",
  "description": "A powerful, cross-browser userscript manager",
  "private": true,
  "scripts": {
    "build": "bun run build.ts",
    "build:chrome": "bun run build.ts --target chrome",
    "build:firefox": "bun run build.ts --target firefox",
    "build:safari": "bun run build.ts --target safari",
    "dev": "bun run build.ts --watch",
    "dev:chrome": "bun run build.ts --target chrome --watch",
    "icons": "bun run scripts/generate-icons.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.18.3",
    "@codemirror/commands": "^6.7.1",
    "@codemirror/lang-javascript": "^6.2.2",
    "@codemirror/state": "^6.5.0",
    "@codemirror/theme-one-dark": "^6.1.2",
    "@codemirror/view": "^6.35.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "webextension-polyfill": "^0.12.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.0.0",
    "@types/chrome": "^0.0.304",
    "@types/node": "^25.3.3",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/webextension-polyfill": "^0.12.1",
    "esbuild": "^0.24.2",
    "sharp": "^0.33.5",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2"
  },
  "trustedDependencies": [
    "@parcel/watcher"
  ]
}
