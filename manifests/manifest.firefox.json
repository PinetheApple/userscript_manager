{
  "manifest_version": 2,
  "name": "ScriptFlow",
  "version": "0.0.1",
  "description": "Userscript manager — run custom JavaScript on any website",
  "permissions": [
    "storage",
    "activeTab",
    "<all_urls>"
  ],
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content.js"],
    "run_at": "document_start"
  }],
  "browser_action": {
    "default_popup": "shell.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_ui": {
    "page": "manager.html",
    "open_in_tab": true
  },
  "web_accessible_resources": ["editor.html"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
